{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "autoapprove",
	"main": "src/index.ts",
	"compatibility_date": "2026-06-23",
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"compatibility_flags": [
		"nodejs_compat"
	],
	"placement": {
    "mode": "smart"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "prod-d1",
      "database_id": "fd35fa96-3938-449d-87d5-80ec224a3403"
    }
  ]
}
